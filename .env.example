DATABASE_URL="postgresql://forge:forge@localhost:5432/klingdom_forge?schema=public"

# Auth.js / Google Workspace SSO
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
ALLOWED_EMAIL_DOMAIN="crossian.com"
SUPER_ADMIN_EMAILS="hoang.vietnguyen@crossian.com,minh.hoang@crossian.com"
# Production only (VPS behind a proxy): the app's public URL, e.g. https://forge.example.com
# Local dev infers the host automatically, so this can stay empty locally.
AUTH_URL=""

# Kling API (per-account keys are stored in the DB; this only overrides the host)
KLING_BASE_URL="https://api-singapore.klingai.com"

# 32-byte hex key for encrypting Kling account secrets at rest (generate: openssl rand -hex 32)
KLING_ENC_KEY=""

# Folder where uploaded source images are stored (path is kept in the DB, file on disk)
UPLOAD_DIR=""

# Object storage (Cloudflare R2, S3-compatible). Required — source images, motion
# reference videos and thumbnails live here so Kling can fetch them by public URL.
# Get these from the Cloudflare dashboard → R2:
#   S3_ENDPOINT    Account endpoint: https://<account_id>.r2.cloudflarestorage.com
#   S3_BUCKET      The bucket name you created
#   S3_ACCESS_KEY  R2 API token access key id (R2 → Manage API Tokens)
#   S3_SECRET_KEY  R2 API token secret (shown once at creation — copy it then)
#   S3_PUBLIC_URL  Public bucket base URL: https://pub-xxxx.r2.dev (or a custom domain)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""

# Optional: enables the in-browser Google Drive Picker UI for selecting files/folders.
# Without these, the Studio falls back to pasting a Google Drive file/folder link or ID.
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=""
NEXT_PUBLIC_GOOGLE_APP_ID=""
# Optional safety cap for folder imports
GOOGLE_DRIVE_MAX_IMPORT_FILES="150"
